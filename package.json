{
  "name": "intent-translator-agent",
  "version": "0.1.0",
  "description": "NLU Orchestrator Agent — bridges natural language and business process automation for Vietnamese institutional contexts",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "agent": "tsx src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "chromadb": "^1.8.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "grammy": "^1.43.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.8.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}

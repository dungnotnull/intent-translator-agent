# ── intent-translator-agent — Environment Variables ──

# ── Server ──
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Python ML Inference Server ──
ML_INFERENCE_URL=http://localhost:8001
ML_MODEL_DIR=src/ml/intent-classifier/models
ML_DOMAIN=university

# ── Deployment Mode ──
# local | hybrid | cloud
# local: All ML runs locally (PhoBERT + Ollama + Whisper) — no internet needed
# hybrid: Local SLM primary + Cloud LLM fallback (recommended for most deployments)
# cloud: All ML via cloud APIs (not recommended for personal data)
DEPLOYMENT_MODE=hybrid

# ── Anthropic Claude (LLM Fallback) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_MAX_TOKENS=200
ANTHROPIC_TEMPERATURE=0.1

# ── Ollama (Offline LLM Fallback) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Redis (Session Store) ──
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL=3600

# ── ChromaDB (Knowledge Base Vector Store) ──
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=intent-translator-kb

# ── Google Cloud Speech (Optional — for cloud/hybrid modes) ──
GOOGLE_SPEECH_API_KEY=
GOOGLE_TTS_LANGUAGE_CODE=vi-VN
GOOGLE_TTS_VOICE_NAME=vi-VN-Wavenet-A

# ── Offline Mode ──
OFFLINE_MODE=false

# ── University SIS API (Example) ──
UNIVERSITY_SIS_API_URL=http://localhost:8080/api
UNIVERSITY_SIS_API_KEY=

# ── Government Portal API (Example) ──
GOVERNMENT_PORTAL_API_URL=https://dichvucong.gov.vn/api
GOVERNMENT_PORTAL_API_KEY=

# ── Rate Limiting ──
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# ── Logging ──
LOG_LEVEL=debug
AUDIT_LOG_PII_MASK=true
